{
  "mcpServers": {
    "webhook": {
      "command": "bun",
      "args": [
        "${CLAUDE_PROJECT_DIR}/webhook.ts"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "serena": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "mcp-serena",
        "serena",
        "start-mcp-server",
        "--transport",
        "stdio"
      ]
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "mcp/sequentialthinking"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    }
  }
}
