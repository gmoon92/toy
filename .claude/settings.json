{
  "env": {
    "CLAUDE_TMP_DIR": "${CLAUDE_PROJECT_DIR}/.claude/.tmp",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "CLAUDE_CODE_EFFORT_LEVEL": "high",
    "ENABLE_LSP_TOOL": "1",
    "MCP_TIMEOUT": "1000"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "mcp__serena__*",
      "mcp__sequential-thinking__*",
      "mcp__context7__*",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*credentials*)",
      "Bash(sudo *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "context7",
    "serena",
    "sequential-thinking",
    "chrome-devtools"
  ],
  "disabledMcpjsonServers": [
    "playwright",
    "shrimp-task-manager"
  ],
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/notification.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "kotlin-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true
  },
  "language": "korean",
  "alwaysThinkingEnabled": true,
  "companyAnnouncements": [
    "  ______                            \n /_  __/___  __  __                 \n  / / / __ \\/ / / /                 \n / / / /_/ / /_/ /                  \n/_/  \\____/\\__, /                   \n   ____ __/____/_  ____  ____  ____ \n  / __ `/ __ `__ \\/ __ \\/ __ \\/ __ \\\n / /_/ / / / / / / /_/ / /_/ / / / /\n \\__, /_/ /_/ /_/\\____/\\____/_/ /_/ \n/____/                              \n\n@github: https://github.com/gmoon92\nFont: Slant with https://www.patorjk.com/software/taag/#p=display&f=Slant"
  ],
  "autoUpdatesChannel": "latest",
  "teammateMode": "tmux"
}
